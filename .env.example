APP_PORT=3333

# ── Monero Nodes ──────────────────────────────────────────────────────────────
# Add as many nodes as you like (MONERO_NODE_1, MONERO_NODE_2, MONERO_NODE_3…).
# The backend tries node 1 first, falls back to node 2, etc. 
# Unhealthy nodes are re-checked every 5 minutes and promoted back automatically.
# Comment out any node block to disable it.

MONERO_NODE_1_HOST=192.168.0.12
MONERO_NODE_1_PORT=18081
MONERO_NODE_1_USER=monero
MONERO_NODE_1_PASS=your-rpc-password-here
# MONERO_NODE_1_TLS=false

# MONERO_NODE_2_HOST=xmr-node.cakewallet.com
# MONERO_NODE_2_PORT=18081
# MONERO_NODE_2_TLS=true



